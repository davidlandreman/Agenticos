# BusyBox config overrides for AgenticOS.
#
# These are appended on top of `make defconfig` by the Makefile, then
# `make oldconfig` canonicalizes. Order: build-time flags first, then
# disabled applet categories. Keep this list small and explainable.
#
# Keep in sync with src/userland/bin_namespace.rs — see the plan
# `docs/plans/2026-05-16-002-feat-busybox-coreutils-userland-plan.md`
# (U3) for the convention.

# ---------------- build-time flags ----------------

# Static link — the kernel ELF loader only accepts ET_EXEC, and BB.ELF
# needs to run with no runtime loader.
CONFIG_STATIC=y

# No PIE — same reason. CONFIG_EXTRA_LDFLAGS in the Makefile adds
# -no-pie; this flag drops PIE-default toolchain behavior at the
# busybox build-system level.
CONFIG_PIE=n

# ---------------- disabled applets (no kernel support) ----------------

# Editor — BusyBox vi is the project's lightweight terminal editor. The
# synthetic /bin namespace also exposes the familiar `vim` spelling as an
# alias that dispatches to this applet.
CONFIG_VI=y

# Init / shutdown — there is no SysV/runit-style init, and halt/poweroff
# would need ACPI shutdown plumbing we don't have.
CONFIG_INIT=n
CONFIG_LINUXRC=n
CONFIG_HALT=n
CONFIG_POWEROFF=n
CONFIG_REBOOT=n
CONFIG_RUNLEVEL=n

# Login / passwd / accounts — no shadow file, no PAM, no setuid path.
CONFIG_LOGIN=n
CONFIG_SULOGIN=n
CONFIG_GETTY=n
CONFIG_PASSWD=n
CONFIG_ADDUSER=n
CONFIG_ADDGROUP=n
CONFIG_DELUSER=n
CONFIG_DELGROUP=n
CONFIG_SU=n
CONFIG_CHPASSWD=n
CONFIG_CRYPTPW=n
CONFIG_MKPASSWD=n
CONFIG_VLOCK=n

# Daemons — no fork-to-background lifecycle support, no syslog.
CONFIG_SYSLOGD=n
CONFIG_KLOGD=n
CONFIG_LOGGER=n
CONFIG_LOGREAD=n
CONFIG_CROND=n
CONFIG_CRONTAB=n
CONFIG_ACPID=n
CONFIG_WATCHDOG=n
CONFIG_MDEV=n
CONFIG_RUNSV=n
CONFIG_RUNSVDIR=n
CONFIG_SVC=n
CONFIG_SVLOGD=n
CONFIG_SVOK=n
CONFIG_CHPST=n
CONFIG_SETUIDGID=n
CONFIG_ENVUIDGID=n
CONFIG_ENVDIR=n
CONFIG_SOFTLIMIT=n

# Module loading — no kernel module support.
CONFIG_INSMOD=n
CONFIG_RMMOD=n
CONFIG_LSMOD=n
CONFIG_MODINFO=n
CONFIG_MODPROBE=n
CONFIG_DEPMOD=n
CONFIG_MODPROBE_SMALL=n

# Mount / swap / block device / filesystem creation — FAT mount is
# read-only and there's no swap subsystem.
CONFIG_MOUNT=n
CONFIG_UMOUNT=n
CONFIG_SWAPON=n
CONFIG_SWAPOFF=n
CONFIG_LOSETUP=n
CONFIG_BLOCKDEV=n
CONFIG_FDISK=n
CONFIG_SFDISK=n
CONFIG_MKE2FS=n
CONFIG_FSCK=n
CONFIG_FSCK_MINIX=n
CONFIG_MKFS_MINIX=n
CONFIG_MKFS_VFAT=n
CONFIG_MKFS_EXT2=n
CONFIG_MKFS_REISER=n
CONFIG_MKDOSFS=n
CONFIG_MKSWAP=n
CONFIG_TUNE2FS=n
CONFIG_BLKID=n
CONFIG_BLKDISCARD=n
CONFIG_FREERAMDISK=n
CONFIG_FDFLUSH=n
CONFIG_FSTRIM=n
CONFIG_FSFREEZE=n
CONFIG_PIVOT_ROOT=n
CONFIG_SWITCH_ROOT=n
CONFIG_CHROOT=n

# Networking — AgenticOS owns DHCP and exposes an IPv4-only socket subset.
# Keep interface control, daemons, IPv6, FTP/TFTP, and TLS off. The enabled
# user commands are ping, nc, nslookup, and HTTP-only wget.
CONFIG_FEATURE_IPV6=n
CONFIG_INETD=n
CONFIG_HTTPD=n
CONFIG_TELNETD=n
CONFIG_FTPD=n
CONFIG_FTPGET=n
CONFIG_FTPPUT=n
CONFIG_TFTPD=n
CONFIG_TFTP=n
CONFIG_DNSD=n
CONFIG_NTPD=n
CONFIG_UDHCPC=n
CONFIG_UDHCPD=n
CONFIG_NSLOOKUP=y
CONFIG_FEATURE_NSLOOKUP_BIG=y
CONFIG_TRACEROUTE=n
CONFIG_TRACEROUTE6=n
CONFIG_PING=y
CONFIG_PING6=n
CONFIG_NETSTAT=n
CONFIG_ROUTE=n
CONFIG_IFCONFIG=n
CONFIG_IFUP=n
CONFIG_IFDOWN=n
CONFIG_IP=n
CONFIG_IPADDR=n
CONFIG_IPLINK=n
CONFIG_IPROUTE=n
CONFIG_IPTUNNEL=n
CONFIG_IPNEIGH=n
CONFIG_IPRULE=n
CONFIG_NAMEIF=n
CONFIG_ARP=n
CONFIG_ARPING=n
CONFIG_BRCTL=n
CONFIG_ETHER_WAKE=n
CONFIG_FAKEIDENTD=n
CONFIG_PSCAN=n
CONFIG_SLATTACH=n
CONFIG_TCPSVD=n
CONFIG_UDPSVD=n
CONFIG_TUNCTL=n
CONFIG_WGET=y
CONFIG_FEATURE_WGET_HTTPS=n
CONFIG_FEATURE_WGET_OPENSSL=n
CONFIG_NC=y
CONFIG_SSL_CLIENT=n
CONFIG_TLS=n
CONFIG_FEATURE_WGET_FTP=n
CONFIG_TELNET=n
CONFIG_LPD=n
CONFIG_LPR=n
CONFIG_LPQ=n
CONFIG_NBDCLIENT=n
CONFIG_DNSDOMAINNAME=n
CONFIG_IPCALC=n
CONFIG_DUMPLEASES=n
CONFIG_ZCIP=n
CONFIG_TC=n
CONFIG_HOSTID=n

# TTY / terminal control. `reset` only needs the termios controls and VT100
# RIS/attribute/cursor sequences implemented by the PTY + terminal emulator.
# The remaining applets need Linux virtual-console, keyboard, framebuffer, or
# TIOCSWINSZ controls that AgenticOS does not expose.
CONFIG_RESET=y
CONFIG_FBSET=n
CONFIG_OPENVT=n
CONFIG_DEALLOCVT=n
CONFIG_CHVT=n
CONFIG_SETCONSOLE=n
CONFIG_KBD_MODE=n
CONFIG_RESIZE=n
CONFIG_LOADKMAP=n
CONFIG_LOADFONT=n
CONFIG_SETFONT=n
CONFIG_DUMPKMAP=n
CONFIG_SHOWKEY=n

# Misc that needs syscalls we don't have or that exposes pointless surface.
# GNU binutils owns /bin/strings; keep the synthetic namespace disjoint.
CONFIG_STRINGS=n
CONFIG_NICE=n
CONFIG_RENICE=n
CONFIG_CHRT=n
CONFIG_TASKSET=n
CONFIG_IPCRM=n
CONFIG_IPCS=n
CONFIG_NSENTER=n
CONFIG_UNSHARE=n
CONFIG_SETSID=n
CONFIG_SETARCH=n
CONFIG_LINUX32=n
CONFIG_LINUX64=n
CONFIG_RTCWAKE=n
CONFIG_HWCLOCK=n
CONFIG_ADJTIMEX=n
CONFIG_BOOTCHARTD=n
# The synthetic /proc plus sysinfo(2) now cover the fields consumed by the
# standard process/memory monitors. `top` is intentionally single-CPU and
# limited to AgenticOS's ring-3 process view.
CONFIG_FREE=y
CONFIG_TOP=y
# `/proc/<pid>/task` and `/proc/<pid>/smaps` are not synthesized, so do not
# advertise top's thread or memory-map modes yet.
CONFIG_FEATURE_SHOW_THREADS=n
CONFIG_FEATURE_TOPMEM=n
CONFIG_IOSTAT=n
CONFIG_MPSTAT=n
CONFIG_NMETER=n
CONFIG_POWERTOP=n
CONFIG_LSPCI=n
CONFIG_LSUSB=n
CONFIG_LSSCSI=n
CONFIG_FUSER=n
CONFIG_BLKSIZE=n
CONFIG_MICROCOM=n
CONFIG_INOTIFYD=n

# Shells — zsh is our shell. BusyBox's ash stays enabled to back
# `/bin/sh`. Disable the others.
CONFIG_HUSH=n
CONFIG_MSH=n
