# Personal Claude Code permissions (shared settings.json IS tracked)
.claude/settings.local.json

# Conductor per-workspace overrides
.conductor/run.local.sh

# Rust build artifacts
/target/
Cargo.lock

# OS development artifacts
*.img
*.iso
*.bin
*.o
*.a

# Bootloader images
/target/bootloader/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Debug files
*.pdb

# QEMU files
*.log
qemu.pid

# Backup files
*.bak
*.backup
*.orig

# Temporary files
*.tmp
.tmp/

# Host-share folder mounted into the guest at /host. Only the seed files
# (.gitkeep, HELLO.TXT, HOST.TXT) are tracked; everything else is local.
host_share/*
!host_share/.gitkeep
!host_share/HELLO.TXT
!host_share/HOST.TXT
